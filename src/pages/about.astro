---
import Layout from "../layouts/Layout.astro";

const team = [
  { name: "Rachel B. Jordan", title: "Founder & CEO", bio: "15+ years in tech recruiting. Previously led talent at two YC-backed startups." },
  { name: "David Kim", title: "Head of Engineering Recruiting", bio: "Former SWE turned recruiter. Specializes in backend and infrastructure roles." },
  { name: "Aisha Patel", title: "AI & ML Practice Lead", bio: "PhD in CS. Bridges the gap between research talent and production ML teams." },
  { name: "James Okafor", title: "Client Success Director", bio: "Ensures every partnership delivers results. 10+ years in B2B tech services." },
  { name: "Maria Santos", title: "Senior Technical Recruiter", bio: "Full-stack recruiting specialist. Known for filling hard-to-close senior roles." },
  { name: "Alex Chen", title: "Recruiting Operations Lead", bio: "Optimizes our sourcing pipelines and candidate experience from first touch to offer." },
];
---

<Layout title="About">
  <!-- Hero -->
  <section class="hero-glow grid-pattern px-6 py-24">
    <div class="mx-auto max-w-7xl text-center">
      <h1 class="animate-fade-up text-4xl font-black md:text-5xl lg:text-6xl">
        The Team Behind <span class="text-primary">Your Next Hire</span>
      </h1>
      <p class="animate-fade-up delay-100 mx-auto mt-6 max-w-2xl text-lg text-muted">
        We're recruiters who speak engineering. Founded by technologists, built for the companies pushing what's possible.
      </p>
    </div>
  </section>

  <!-- Story Section -->
  <section class="px-6 py-24">
    <div class="mx-auto max-w-7xl">
      <div class="grid items-center gap-16 lg:grid-cols-2">
        <div>
          <span class="text-sm font-bold uppercase tracking-wider text-primary">Our Story</span>
          <h2 class="mt-4 text-3xl font-black md:text-4xl">
            Built Different, on Purpose
          </h2>
          <div class="mt-6 space-y-4 text-muted">
            <p>
              RBJ was founded on a simple frustration: most recruiting agencies don't understand the technology their candidates work with. They can't tell a systems engineer from a site reliability engineer, or a fine-tuned model from a foundation model.
            </p>
            <p>
              We built RBJ to be the agency we wished existed — one staffed by people who've shipped code, reviewed PRs, and sat in architecture meetings. We speak your language because we've lived it.
            </p>
            <p>
              Today, we partner with over 200 tech companies and AI startups, from seed-stage to public, to place the engineers and technical leaders who move products forward.
            </p>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="rounded-xl border border-surface/50 bg-surface/20 p-6 text-center">
            <p class="text-3xl font-black text-primary">2019</p>
            <p class="mt-2 text-sm text-muted">Founded</p>
          </div>
          <div class="rounded-xl border border-surface/50 bg-surface/20 p-6 text-center">
            <p class="text-3xl font-black text-primary">32</p>
            <p class="mt-2 text-sm text-muted">Team Members</p>
          </div>
          <div class="rounded-xl border border-surface/50 bg-surface/20 p-6 text-center">
            <p class="text-3xl font-black text-primary">500+</p>
            <p class="mt-2 text-sm text-muted">Placements</p>
          </div>
          <div class="rounded-xl border border-surface/50 bg-surface/20 p-6 text-center">
            <p class="text-3xl font-black text-primary">96%</p>
            <p class="mt-2 text-sm text-muted">Retention Rate</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="border-t border-surface/50 px-6 py-24">
    <div class="mx-auto max-w-7xl">
      <div class="text-center">
        <h2 class="text-3xl font-black md:text-4xl">What We Stand For</h2>
      </div>
      <div class="mt-16 grid gap-8 md:grid-cols-3">
        {[
          { title: "Technical Depth", description: "We don't keyword-match resumes. Our team evaluates real engineering ability, system design thinking, and technical communication." },
          { title: "Speed Without Shortcuts", description: "Our average time-to-present is 14 days — not because we cut corners, but because our network and process are that dialed in." },
          { title: "Partnership Over Transactions", description: "We measure success by retention, not invoice count. Every placement should still feel like a win a year later." },
        ].map((value) => (
          <div class="rounded-xl border border-surface/50 bg-surface/20 p-8">
            <h3 class="text-xl font-bold">{value.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="border-t border-surface/50 px-6 py-24">
    <div class="mx-auto max-w-7xl">
      <div class="text-center">
        <h2 class="text-3xl font-black md:text-4xl">Meet the Team</h2>
        <p class="mt-4 text-muted">The people behind every great placement.</p>
      </div>

      <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {team.map((member) => (
          <div class="group rounded-xl border border-surface/50 bg-surface/20 p-8 text-center transition-all hover:border-primary/30 hover:bg-surface/40">
            <img
              src={`https://placehold.co/120x120/1e293b/60A5FA?text=${member.name.split(" ").map(n => n[0]).join("")}`}
              alt={member.name}
              class="mx-auto h-24 w-24 rounded-full border-2 border-surface"
            />
            <h3 class="mt-6 text-lg font-bold">{member.name}</h3>
            <p class="mt-1 text-sm text-accent">{member.title}</p>
            <p class="mt-3 text-sm text-muted">{member.bio}</p>
            <a href="#" class="mt-4 inline-block text-muted transition-colors hover:text-accent" aria-label={`${member.name} on LinkedIn`}>
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-surface/50 px-6 py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-black md:text-4xl">Want to Work With Us?</h2>
      <p class="mt-4 text-lg text-muted">
        Whether you're a company looking to hire or a recruiter looking to join — we'd love to hear from you.
      </p>
      <a
        href="/contact"
        class="mt-8 inline-block rounded-lg bg-primary px-10 py-4 text-base font-semibold text-white transition-all hover:bg-accent hover:shadow-xl hover:shadow-primary/20"
      >
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
