---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact">
  <!-- Hero -->
  <section class="hero-glow grid-pattern px-6 py-24">
    <div class="mx-auto max-w-7xl text-center">
      <h1 class="animate-fade-up text-4xl font-black md:text-5xl lg:text-6xl">
        Let's <span class="text-primary">Talk</span>
      </h1>
      <p class="animate-fade-up delay-100 mx-auto mt-6 max-w-2xl text-lg text-muted">
        Whether you're hiring or looking for your next role, we're here to help. Reach out and we'll get back to you within 24 hours.
      </p>
    </div>
  </section>

  <!-- Contact Form + Info -->
  <section class="px-6 py-24">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-16 lg:grid-cols-5">
        <!-- Form -->
        <div class="lg:col-span-3">
          <form class="space-y-6" id="contact-form">
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="name" class="block text-sm font-medium text-text">Full Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="mt-2 w-full rounded-lg border border-surface bg-bg px-4 py-3 text-sm text-text placeholder:text-muted/60 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
                  placeholder="Jane Smith"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-text">Work Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="mt-2 w-full rounded-lg border border-surface bg-bg px-4 py-3 text-sm text-text placeholder:text-muted/60 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
                  placeholder="jane@company.com"
                />
              </div>
            </div>

            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="company" class="block text-sm font-medium text-text">Company</label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  class="mt-2 w-full rounded-lg border border-surface bg-bg px-4 py-3 text-sm text-text placeholder:text-muted/60 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
                  placeholder="Acme Corp"
                />
              </div>
              <div>
                <label for="inquiry-type" class="block text-sm font-medium text-text">I am...</label>
                <select
                  id="inquiry-type"
                  name="inquiry-type"
                  class="mt-2 w-full rounded-lg border border-surface bg-bg px-4 py-3 text-sm text-muted focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
                >
                  <option value="hiring">Hiring (I'm looking for talent)</option>
                  <option value="candidate">A Candidate (I'm looking for a role)</option>
                </select>
              </div>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-text">Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="mt-2 w-full rounded-lg border border-surface bg-bg px-4 py-3 text-sm text-text placeholder:text-muted/60 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
                placeholder="Tell us about your hiring needs or the kind of role you're looking for..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full rounded-lg bg-primary px-8 py-4 text-base font-semibold text-white transition-all hover:bg-accent hover:shadow-xl hover:shadow-primary/20 sm:w-auto"
            >
              Send Message
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="lg:col-span-2">
          <div class="space-y-8">
            <div>
              <h3 class="text-sm font-bold uppercase tracking-wider text-primary">Email</h3>
              <a href="mailto:hello@rbjrecruiting.com" class="mt-2 block text-lg text-text transition-colors hover:text-accent">
                hello@rbjrecruiting.com
              </a>
            </div>
            <div>
              <h3 class="text-sm font-bold uppercase tracking-wider text-primary">Phone</h3>
              <a href="tel:+14155550123" class="mt-2 block text-lg text-text transition-colors hover:text-accent">
                (415) 555-0123
              </a>
            </div>
            <div>
              <h3 class="text-sm font-bold uppercase tracking-wider text-primary">Office</h3>
              <p class="mt-2 text-lg text-text">
                548 Market Street, Suite 300<br />
                San Francisco, CA 94104
              </p>
            </div>
            <div>
              <h3 class="text-sm font-bold uppercase tracking-wider text-primary">Hours</h3>
              <p class="mt-2 text-text">Monday – Friday, 9am – 6pm PT</p>
            </div>

            <div class="rounded-xl border border-surface/50 bg-surface/20 p-6">
              <h3 class="font-bold">Quick Response Guarantee</h3>
              <p class="mt-2 text-sm text-muted">
                Every inquiry gets a response within 24 hours. For urgent hiring needs, call us directly and we'll prioritize your request.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
  const form = document.getElementById("contact-form") as HTMLFormElement;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const btn = form.querySelector("button[type='submit']") as HTMLButtonElement;
    btn.textContent = "Message Sent!";
    btn.classList.remove("bg-primary", "hover:bg-accent");
    btn.classList.add("bg-green-600");
    btn.disabled = true;

    setTimeout(() => {
      btn.textContent = "Send Message";
      btn.classList.remove("bg-green-600");
      btn.classList.add("bg-primary", "hover:bg-accent");
      btn.disabled = false;
      form.reset();
    }, 3000);
  });
  });
</script>
