---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="hero-glow grid-pattern relative overflow-hidden px-6 py-24 md:py-36">
    <div class="mx-auto max-w-7xl text-center">
      <div class="animate-fade-up">
        <span class="inline-block rounded-full border border-primary/30 bg-primary/10 px-4 py-1.5 text-xs font-medium uppercase tracking-wider text-accent">
          Tech Recruiting, Reimagined
        </span>
      </div>

      <h1 class="animate-fade-up delay-100 mt-8 text-4xl font-black leading-tight tracking-tight md:text-6xl lg:text-7xl">
        We Find the Engineers<br />
        <span class="text-primary">Who Build the Future</span>
      </h1>

      <p class="animate-fade-up delay-200 mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-muted md:text-xl">
        RBJ partners with AI startups and tech companies to source, vet, and place
        world-class engineering talent — fast, precisely, and at scale.
      </p>

      <div class="animate-fade-up delay-300 mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="/contact"
          class="w-full rounded-lg bg-primary px-8 py-4 text-base font-semibold text-white transition-all hover:bg-accent hover:shadow-xl hover:shadow-primary/20 sm:w-auto"
        >
          Hire Now
        </a>
        <a
          href="/roles"
          class="w-full rounded-lg border border-surface bg-surface/50 px-8 py-4 text-base font-semibold text-text transition-all hover:border-primary/50 hover:bg-surface sm:w-auto"
        >
          View Open Roles
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="border-y border-surface/50 bg-surface/30">
    <div class="mx-auto grid max-w-7xl grid-cols-2 gap-8 px-6 py-12 md:grid-cols-4">
      {[
        { value: "500+", label: "Placements Made" },
        { value: "14 Days", label: "Avg. Match Time" },
        { value: "96%", label: "Retention Rate" },
        { value: "200+", label: "Partner Companies" },
      ].map((stat) => (
        <div class="text-center">
          <p class="text-3xl font-black text-primary md:text-4xl">{stat.value}</p>
          <p class="mt-2 text-sm text-muted">{stat.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Client Logos -->
  <section class="px-6 py-20">
    <div class="mx-auto max-w-7xl">
      <p class="text-center text-sm font-medium uppercase tracking-widest text-muted">
        Trusted by teams at
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-10 md:gap-16">
        {["TechCorp", "NeuralAI", "CloudOps", "DataForge", "QuantumLab"].map((name) => (
          <div class="group flex items-center gap-2 opacity-40 transition-opacity hover:opacity-80">
            <svg class="h-8 w-8 text-muted" viewBox="0 0 32 32" fill="none">
              <rect width="32" height="32" rx="8" fill="currentColor" fill-opacity="0.15" />
              <circle cx="16" cy="16" r="6" stroke="currentColor" stroke-width="2" />
            </svg>
            <span class="text-lg font-semibold text-muted">{name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="border-t border-surface/50 px-6 py-24">
    <div class="mx-auto max-w-7xl">
      <div class="text-center">
        <h2 class="text-3xl font-black md:text-4xl">How It Works</h2>
        <p class="mt-4 text-muted">Three steps to your next great hire.</p>
      </div>

      <div class="mt-16 grid gap-8 md:grid-cols-3">
        {[
          {
            step: "01",
            title: "Tell Us What You Need",
            description:
              "Share your role requirements, team culture, and timeline. We learn your stack, your standards, and what 'great' looks like for your team.",
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />`,
          },
          {
            step: "02",
            title: "We Source & Vet",
            description:
              "Our recruiters tap into a vetted network of senior engineers, ML specialists, and technical leaders. Every candidate is screened for skill and culture fit.",
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />`,
          },
          {
            step: "03",
            title: "You Hire with Confidence",
            description:
              "Meet pre-qualified candidates ready to contribute from day one. We handle coordination, negotiation, and onboarding support.",
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />`,
          },
        ].map((item) => (
          <div class="group rounded-xl border border-surface/50 bg-surface/20 p-8 transition-all hover:border-primary/30 hover:bg-surface/40">
            <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10">
              <svg class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" set:html={item.icon} />
            </div>
            <span class="mt-6 block text-sm font-bold uppercase tracking-wider text-primary">{item.step}</span>
            <h3 class="mt-2 text-xl font-bold">{item.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="border-t border-surface/50 px-6 py-24">
    <div class="mx-auto max-w-7xl">
      <div class="text-center">
        <h2 class="text-3xl font-black md:text-4xl">What Our Partners Say</h2>
        <p class="mt-4 text-muted">Hear from CTOs and engineering leaders who trust RBJ.</p>
      </div>

      <div class="mt-16 grid gap-8 md:grid-cols-3">
        {[
          {
            quote:
              "RBJ filled three senior ML roles in under two weeks. The quality of candidates was unlike anything we'd seen from other agencies.",
            name: "Sarah Chen",
            role: "CTO, NeuralAI",
          },
          {
            quote:
              "We were scaling from 10 to 50 engineers. RBJ didn't just find us candidates — they understood the kind of culture we were building.",
            name: "Marcus Johnson",
            role: "VP Engineering, CloudOps",
          },
          {
            quote:
              "The retention rate speaks for itself. Every engineer RBJ placed on our team is still here 18 months later.",
            name: "Emily Park",
            role: "Head of Talent, DataForge",
          },
        ].map((testimonial) => (
          <div class="rounded-xl border border-surface/50 bg-surface/20 p-8">
            <svg class="h-8 w-8 text-primary/40" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11h4v10H0z" />
            </svg>
            <p class="mt-4 text-sm leading-relaxed text-muted">{testimonial.quote}</p>
            <div class="mt-6 flex items-center gap-3">
              <img
                src="https://placehold.co/40x40/1e293b/60A5FA?text=avatar"
                alt={testimonial.name}
                class="h-10 w-10 rounded-full"
              />
              <div>
                <p class="text-sm font-semibold">{testimonial.name}</p>
                <p class="text-xs text-muted">{testimonial.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="border-t border-surface/50 px-6 py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-black md:text-4xl">Ready to Build Your Dream Team?</h2>
      <p class="mt-4 text-lg text-muted">
        Let's talk about your hiring goals. No commitment, no pressure — just a conversation about how we can help.
      </p>
      <a
        href="/contact"
        class="mt-8 inline-block rounded-lg bg-primary px-10 py-4 text-base font-semibold text-white transition-all hover:bg-accent hover:shadow-xl hover:shadow-primary/20"
      >
        Start a Conversation
      </a>
    </div>
  </section>
</Layout>
