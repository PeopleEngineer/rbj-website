---
import Layout from "../layouts/Layout.astro";

const roles = [
  {
    title: "Senior Backend Engineer",
    company: "NeuralAI",
    location: "San Francisco, CA",
    type: "Full-Time",
    salary: "$180K – $240K",
    tags: ["Python", "Go", "Kubernetes"],
    posted: "2 days ago",
  },
  {
    title: "Staff ML Engineer",
    company: "DataForge",
    location: "Remote (US)",
    type: "Full-Time",
    salary: "$220K – $300K",
    tags: ["PyTorch", "Transformers", "MLOps"],
    posted: "3 days ago",
  },
  {
    title: "Frontend Engineer (React)",
    company: "CloudOps",
    location: "New York, NY",
    type: "Full-Time",
    salary: "$160K – $210K",
    tags: ["React", "TypeScript", "Next.js"],
    posted: "1 day ago",
  },
  {
    title: "DevOps / Platform Engineer",
    company: "QuantumLab",
    location: "Austin, TX",
    type: "Contract",
    salary: "$100 – $140/hr",
    tags: ["AWS", "Terraform", "CI/CD"],
    posted: "5 days ago",
  },
  {
    title: "AI Research Scientist",
    company: "NeuralAI",
    location: "Remote (Global)",
    type: "Full-Time",
    salary: "$250K – $350K",
    tags: ["LLMs", "RLHF", "Research"],
    posted: "1 week ago",
  },
  {
    title: "Engineering Manager",
    company: "TechCorp",
    location: "Seattle, WA",
    type: "Full-Time",
    salary: "$200K – $270K",
    tags: ["Leadership", "Agile", "Distributed Systems"],
    posted: "4 days ago",
  },
  {
    title: "Data Engineer",
    company: "DataForge",
    location: "Remote (US)",
    type: "Full-Time",
    salary: "$150K – $200K",
    tags: ["Spark", "dbt", "Snowflake"],
    posted: "3 days ago",
  },
  {
    title: "Full-Stack Engineer",
    company: "CloudOps",
    location: "San Francisco, CA",
    type: "Contract-to-Hire",
    salary: "$90 – $120/hr",
    tags: ["Node.js", "React", "PostgreSQL"],
    posted: "6 days ago",
  },
  {
    title: "VP of Engineering",
    company: "TechCorp",
    location: "New York, NY",
    type: "Full-Time",
    salary: "$300K – $400K+",
    tags: ["Executive", "Strategy", "Scaling"],
    posted: "1 week ago",
  },
];

const locations = ["All Locations", "San Francisco, CA", "New York, NY", "Remote (US)", "Remote (Global)", "Austin, TX", "Seattle, WA"];
const types = ["All Types", "Full-Time", "Contract", "Contract-to-Hire"];
---

<Layout title="Open Roles">
  <!-- Hero -->
  <section class="hero-glow grid-pattern px-6 py-24">
    <div class="mx-auto max-w-7xl text-center">
      <h1 class="animate-fade-up text-4xl font-black md:text-5xl lg:text-6xl">
        Open <span class="text-primary">Roles</span>
      </h1>
      <p class="animate-fade-up delay-100 mx-auto mt-6 max-w-2xl text-lg text-muted">
        Browse current opportunities at top tech companies and AI startups. All roles are actively hiring through RBJ.
      </p>
    </div>
  </section>

  <!-- Filters + Roles -->
  <section class="px-6 py-16">
    <div class="mx-auto max-w-7xl">
      <!-- Filters -->
      <div class="flex flex-col gap-4 rounded-xl border border-surface/50 bg-surface/20 p-6 sm:flex-row">
        <div class="flex-1">
          <input
            type="text"
            id="search-input"
            placeholder="Search by title, company, or skill..."
            class="w-full rounded-lg border border-surface bg-bg px-4 py-3 text-sm text-text placeholder:text-muted/60 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
          />
        </div>
        <select
          id="location-filter"
          class="rounded-lg border border-surface bg-bg px-4 py-3 text-sm text-muted focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
        >
          {locations.map((loc) => (
            <option value={loc}>{loc}</option>
          ))}
        </select>
        <select
          id="type-filter"
          class="rounded-lg border border-surface bg-bg px-4 py-3 text-sm text-muted focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
        >
          {types.map((type) => (
            <option value={type}>{type}</option>
          ))}
        </select>
      </div>

      <!-- Role Cards -->
      <div id="roles-grid" class="mt-8 grid gap-4">
        {roles.map((role) => (
          <div
            class="role-card group flex flex-col gap-4 rounded-xl border border-surface/50 bg-surface/20 p-6 transition-all hover:border-primary/30 hover:bg-surface/40 sm:flex-row sm:items-center sm:justify-between"
            data-title={role.title.toLowerCase()}
            data-company={role.company.toLowerCase()}
            data-location={role.location}
            data-type={role.type}
            data-tags={role.tags.join(" ").toLowerCase()}
          >
            <div class="flex-1">
              <div class="flex flex-wrap items-center gap-3">
                <h3 class="text-lg font-bold">{role.title}</h3>
                <span class="rounded-full bg-primary/10 px-3 py-0.5 text-xs font-medium text-accent">
                  {role.type}
                </span>
              </div>
              <div class="mt-2 flex flex-wrap items-center gap-4 text-sm text-muted">
                <span class="flex items-center gap-1">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                  </svg>
                  {role.company}
                </span>
                <span class="flex items-center gap-1">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  {role.location}
                </span>
                <span class="font-semibold text-text">{role.salary}</span>
              </div>
              <div class="mt-3 flex flex-wrap gap-2">
                {role.tags.map((tag) => (
                  <span class="rounded-md border border-surface bg-bg px-2 py-1 text-xs text-muted">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
            <div class="flex items-center gap-4">
              <span class="text-xs text-muted">{role.posted}</span>
              <a
                href="/contact"
                class="shrink-0 rounded-lg bg-primary px-6 py-2.5 text-sm font-semibold text-white transition-all hover:bg-accent hover:shadow-lg hover:shadow-primary/20"
              >
                Apply
              </a>
            </div>
          </div>
        ))}
      </div>

      <!-- No Results -->
      <div id="no-results" class="mt-12 hidden text-center">
        <p class="text-lg text-muted">No roles match your search. Try adjusting your filters.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-surface/50 px-6 py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-black md:text-4xl">Don't See the Right Role?</h2>
      <p class="mt-4 text-lg text-muted">
        Send us your resume anyway. We regularly source for unlisted and confidential roles at top companies.
      </p>
      <a
        href="/contact"
        class="mt-8 inline-block rounded-lg bg-primary px-10 py-4 text-base font-semibold text-white transition-all hover:bg-accent hover:shadow-xl hover:shadow-primary/20"
      >
        Submit Your Resume
      </a>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
  const searchInput = document.getElementById("search-input") as HTMLInputElement;
  const locationFilter = document.getElementById("location-filter") as HTMLSelectElement;
  const typeFilter = document.getElementById("type-filter") as HTMLSelectElement;
  const cards = document.querySelectorAll(".role-card") as NodeListOf<HTMLElement>;
  const noResults = document.getElementById("no-results");

  function filterRoles() {
    const query = searchInput.value.toLowerCase();
    const location = locationFilter.value;
    const type = typeFilter.value;
    let visible = 0;

    cards.forEach((card) => {
      const title = card.dataset.title || "";
      const company = card.dataset.company || "";
      const tags = card.dataset.tags || "";
      const cardLocation = card.dataset.location || "";
      const cardType = card.dataset.type || "";

      const matchesSearch = !query || title.includes(query) || company.includes(query) || tags.includes(query);
      const matchesLocation = location === "All Locations" || cardLocation === location;
      const matchesType = type === "All Types" || cardType === type;

      if (matchesSearch && matchesLocation && matchesType) {
        card.style.display = "";
        visible++;
      } else {
        card.style.display = "none";
      }
    });

    if (noResults) {
      noResults.classList.toggle("hidden", visible > 0);
    }
  }

  searchInput?.addEventListener("input", filterRoles);
  locationFilter?.addEventListener("change", filterRoles);
  typeFilter?.addEventListener("change", filterRoles);
  });
</script>
