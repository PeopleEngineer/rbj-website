---
import Layout from "../layouts/Layout.astro";

const services = [
  {
    title: "Direct Hire",
    description:
      "Permanent placements for critical roles. We source, screen, and deliver senior engineers, architects, and technical leads who align with your stack and culture.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />`,
    features: ["Full-time permanent roles", "Technical skill validation", "Culture-fit assessment", "90-day placement guarantee"],
  },
  {
    title: "Contract Staffing",
    description:
      "Scale your team on demand with pre-vetted contractors. Ideal for product sprints, infrastructure buildouts, or bridging gaps while you hire permanently.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />`,
    features: ["Flexible engagement terms", "Rapid deployment (48-72 hrs)", "Contract-to-hire options", "Managed team augmentation"],
  },
  {
    title: "Executive Search",
    description:
      "Confidential, white-glove searches for VP Engineering, CTO, and other senior technical leadership roles that will define your company's trajectory.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />`,
    features: ["Confidential retained searches", "Board & investor alignment", "Compensation benchmarking", "Leadership assessment"],
  },
  {
    title: "AI & ML Talent",
    description:
      "Specialized recruiting for machine learning engineers, research scientists, data engineers, and MLOps professionals who can ship real AI products.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />`,
    features: ["ML/AI specialization", "Research-to-production talent", "GPU infrastructure expertise", "LLM & GenAI specialists"],
  },
  {
    title: "Team Buildouts",
    description:
      "Building an engineering org from scratch? We embed with your leadership to hire entire teams — from IC engineers to managers — with a cohesive strategy.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />`,
    features: ["Org design consulting", "Multi-role parallel hiring", "Employer brand support", "Onboarding coordination"],
  },
  {
    title: "Recruiting as a Service",
    description:
      "Embed an RBJ recruiter directly into your hiring workflow. Get a dedicated partner who learns your systems, attends standups, and owns your pipeline.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />`,
    features: ["Embedded recruiter model", "ATS integration", "Weekly pipeline reviews", "Scalable month-to-month"],
  },
];
---

<Layout title="Services">
  <!-- Hero -->
  <section class="hero-glow grid-pattern px-6 py-24">
    <div class="mx-auto max-w-7xl text-center">
      <h1 class="animate-fade-up text-4xl font-black md:text-5xl lg:text-6xl">
        Recruiting Solutions <span class="text-primary">Built for Tech</span>
      </h1>
      <p class="animate-fade-up delay-100 mx-auto mt-6 max-w-2xl text-lg text-muted">
        Whether you're hiring one senior engineer or building an entire AI team, we have a model that fits your needs and timeline.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="px-6 py-24">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => (
          <div class="group flex flex-col rounded-xl border border-surface/50 bg-surface/20 p-8 transition-all hover:border-primary/30 hover:bg-surface/40">
            <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10">
              <svg class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" set:html={service.icon} />
            </div>
            <h3 class="mt-6 text-xl font-bold">{service.title}</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-muted">{service.description}</p>
            <ul class="mt-6 space-y-2">
              {service.features.map((feature) => (
                <li class="flex items-center gap-2 text-sm text-muted">
                  <svg class="h-4 w-4 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>
            <a
              href="/contact"
              class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-accent transition-colors hover:text-primary"
            >
              Learn More
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-surface/50 px-6 py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-black md:text-4xl">Not Sure Which Model Fits?</h2>
      <p class="mt-4 text-lg text-muted">
        Talk to us. We'll recommend the right approach based on your team size, timeline, and budget.
      </p>
      <a
        href="/contact"
        class="mt-8 inline-block rounded-lg bg-primary px-10 py-4 text-base font-semibold text-white transition-all hover:bg-accent hover:shadow-xl hover:shadow-primary/20"
      >
        Schedule a Call
      </a>
    </div>
  </section>
</Layout>
